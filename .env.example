# ===========================================================================
# ZATCA Integration — environment variables
# ===========================================================================
# Two consumers read this file:
#
#   1) `docker compose up`  — auto-loads variables for docker-compose.yml.
#   2) Local Go CLIs (process_bills, credit_notes, etc.) — use the lowercase
#      DB names below (HOST/PORT/DBUSER/PASSWORD/DBNAME), not the compose ones.
#
# Copy to `.env` and fill in real values. Never commit `.env`.
# ===========================================================================

# ---------------------------------------------------------------------------
# (A) docker-compose.yml — daemon container
# ---------------------------------------------------------------------------

# Database connection (required)
DB_USER=zatca_daemon
DB_PASS=changeme                 # <-- REQUIRED
DB_HOST=host.docker.internal     # host machine MySQL
DB_PORT=3306
MASTER_DB=zatca_master

# Optional: separate admin user used only during onboarding
# ADMIN_DB_USER=
# ADMIN_DB_PASS=

# AES-256-GCM key for encrypting ZATCA credentials in the DB (required).
# Generate with:  openssl rand -base64 32
ENCRYPT_KEY=                     # <-- REQUIRED

# Password for the embedded NATS monitoring endpoint http://host:8222 (required).
MONITOR_PASS=                    # <-- REQUIRED

# Host port mappings (override only if 4222/8222 collide with another service)
# NATS_PORT=4222
# NATS_MONITOR_PORT=8222

# SMTP for daemon error-alert emails (optional; defaults to host SMTP on :25)
SMTP_HOST=host.docker.internal
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_FROM=zatca-daemon@localhost

# ---------------------------------------------------------------------------
# (B) Local Go CLIs in cmd/  (NOT used by docker compose)
# ---------------------------------------------------------------------------
HOST=127.0.0.1
PORT=3306
DBUSER=zatca_daemon
PASSWORD=
DBNAME=dev_ifritah

# ---------------------------------------------------------------------------
# (C) Dev-only — used by scripts/, not by Go or compose
# ---------------------------------------------------------------------------
GITHUB_TOKEN=
