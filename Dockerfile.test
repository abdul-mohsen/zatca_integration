FROM golang:1.25 AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /natsdiag ./cmd/natsdiag
RUN CGO_ENABLED=0 go build -o /testrunner ./cmd/testrunner

FROM alpine:3.20
RUN apk add --no-cache curl
COPY --from=builder /natsdiag /usr/local/bin/natsdiag
COPY --from=builder /testrunner /usr/local/bin/testrunner
ENTRYPOINT ["testrunner"]
